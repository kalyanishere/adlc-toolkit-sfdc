// tests/e2e/<componentName>.spec.ts — LWC-focused Playwright spec template
//
// Copy this file to <playwright_specs>/<componentName>.spec.ts (drop the
// `.example` suffix). Replace `componentName`, the navigation target, and
// the feature-specific assertions with the LWC under test.
//
// LWC selector strategy — pick from this order:
//   1. `getByRole(role, { name })` — reads the component the same way an
//      accessibility tool does. This is the most stable selector for any
//      `lightning-button`, `lightning-input` (with a label), `lightning-card`
//      header, etc. SLDS internals can change; the role + accessible name
//      cannot, because they're part of the component's contract.
//   2. `getByLabel('<label text>')` — for `lightning-input`, `lightning-combobox`,
//      `lightning-textarea` where the role is generic.
//   3. `getByTestId('<id>')` — when the LWC template renders an element with
//      `data-testid="<id>"`. This is the recommended LWC pattern for elements
//      that lack a stable role / label (custom buttons, computed regions).
//      You may need to ADD `data-testid` to the LWC template — that's fine,
//      it's additive.
//   4. `getByText('<copy>')` — for buttons / status pills whose user-visible
//      text IS the spec contract.
//
// Brittle locators (test-auditor.md flags these — Major):
//   - `:nth-child(N)`, `:nth-of-type(N)` — DOM order is not a contract
//   - Generated SLDS class fragments (e.g., `.slds-form-element__label_xKj9`)
//   - Autogenerated Lightning ids (e.g., `[id="input-1234"]`)
//   - Tag-name-only selectors at page root (`page.locator('lightning-input').first()`)
//
// Validation-state assertions on `lightning-input`:
//   - DO NOT assert `aria-invalid` on the lightning-input host — Lightning
//     does not guarantee the attribute on the shadow host (test-auditor flags
//     this as Major).
//   - DO assert on the rendered error message text, the `slds-has-error` class
//     on the host, or a `data-testid="error-message"` element rendered by the
//     LWC template.

import { expect, test } from '@playwright/test';

test.describe('<componentName> — Lightning Record page surface', () => {
  // Replace with the surface that hosts your LWC. Common patterns:
  //   /lightning/r/<sObject>/<recordId>/view  — LWC on a record page
  //   /lightning/n/<tabApiName>                — LWC on a custom tab
  //   /lightning/o/<sObject>/list?filterName=Recent  — LWC on a list view
  //   /lightning/page/home                     — LWC on the home page
  const RECORD_URL = '/lightning/r/Account/<recordId>/view';

  test('renders the component @prod-safe', async ({ page }) => {
    await page.goto(RECORD_URL);

    // Stable: card title is part of the LWC contract.
    await expect(
      page.getByRole('heading', { name: '<Card Title>' }),
    ).toBeVisible();

    // Stable: data-testid declared in the LWC template.
    await expect(page.getByTestId('<feature>-summary')).toBeVisible();
  });

  test('handles the primary user action', async ({ page }) => {
    await page.goto(RECORD_URL);

    await page.getByRole('button', { name: '<Action Label>' }).click();

    // Web-first auto-waiting — never use page.waitForTimeout().
    await expect(
      page.getByRole('status', { name: /saved|success/i }),
    ).toBeVisible();
  });

  test('surfaces validation errors on bad input', async ({ page }) => {
    await page.goto(RECORD_URL);

    await page.getByLabel('<Required Field Label>').fill('');
    await page.getByRole('button', { name: 'Save' }).click();

    // Assert on rendered error TEXT, not aria-invalid on the host.
    await expect(page.getByText('<Validation Message>')).toBeVisible();
  });
});

// Mutating spec — clean up everything created in the test.
test.describe('<componentName> — record creation flow', () => {
  const createdIds: string[] = [];

  test.afterAll(async () => {
    if (!createdIds.length) return;
    const { execSync } = await import('node:child_process');
    for (const id of createdIds) {
      execSync(
        `sf data delete record --sobject <sObject> --record-id ${id} --target-org "$SF_TARGET_ORG"`,
        { stdio: 'ignore' },
      );
    }
  });

  test('creates a record through the LWC', async ({ page }) => {
    // Use a deterministic name that survives parallel-worker collisions.
    const name = `E2E <Component> ${process.env.GITHUB_RUN_ID ?? 'local'} ${test.info().workerIndex}`;

    await page.goto('/lightning/o/<sObject>/list');
    await page.getByRole('button', { name: 'New' }).click();
    await page.getByLabel('<Name Field Label>').fill(name);
    await page.getByRole('button', { name: 'Save' }).click();

    // Assert by deterministic field, not auto-generated ID.
    await expect(page.getByRole('heading', { name })).toBeVisible();

    // Capture the ID for cleanup; never assert against it.
    const id = new URL(page.url()).pathname.split('/').filter(Boolean).pop();
    if (id) createdIds.push(id);
  });
});
