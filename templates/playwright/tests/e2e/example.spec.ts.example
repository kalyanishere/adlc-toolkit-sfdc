// tests/e2e/<feature>.spec.ts — example Salesforce LWC e2e spec
//
// Copy this file when scaffolding a new spec. Rename to `<feature>.spec.ts`
// (drop the `.example` suffix). Replace the navigation, selector, and
// assertion bodies with the feature under test.
//
// Style rules (enforced by agents/test-auditor.md):
//   - Use `getByRole`, `getByLabel`, `getByTestId`, `getByText`. NEVER use
//     CSS :nth-child, generated SLDS hash classes, or autogenerated id="…"
//     locators.
//   - Use Playwright's web-first auto-waiting (`toBeVisible`, `toHaveText`).
//     NEVER use `page.waitForTimeout` or `setTimeout` for synchronization.
//   - Tag read-only specs that are safe against prod with `@prod-safe` so
//     the prod project's `grep: /@prod-safe/` filter picks them up.
//   - Specs that mutate org state MUST clean up in afterAll/afterEach.
//   - Authentication comes from storageState.json (seeded by global-setup.ts).
//     NEVER inline passwords, tokens, or accessToken values.

import { expect, test } from '@playwright/test';

test.describe('Account list page', () => {
  test('renders the standard list view @prod-safe', async ({ page }) => {
    await page.goto('/lightning/o/Account/list');

    // Stable, accessibility-driven locators. The "Accounts" heading is part
    // of the spec contract; if the surface stops rendering it, the test
    // SHOULD fail loudly.
    await expect(page.getByRole('heading', { name: 'Accounts' })).toBeVisible();
  });

  test('opens the New Account modal', async ({ page }) => {
    await page.goto('/lightning/o/Account/list');
    await page.getByRole('button', { name: 'New' }).click();

    // Lightning renders the modal in a portal — assert on its visible label.
    await expect(page.getByRole('heading', { name: 'New Account' })).toBeVisible();

    // Validation-state assertions: prefer error-message text over aria-invalid
    // on the lightning-input shadow host (test-auditor flags the latter).
    await page.getByRole('button', { name: 'Save' }).click();
    await expect(page.getByText('Complete this field.')).toBeVisible();
  });
});

// Mutating spec example — note the cleanup hook. Without afterAll, every
// run leaves test data in the org and `test-auditor` flags it as Minor.
test.describe('Account create flow', () => {
  const createdAccountIds: string[] = [];

  test.afterAll(async ({ request }) => {
    if (!createdAccountIds.length) return;
    // Cleanup via sf CLI is fine; an Apex REST endpoint is also fine.
    // The point is that something cleans up.
    const { execSync } = await import('node:child_process');
    for (const id of createdAccountIds) {
      execSync(
        `sf data delete record --sobject Account --record-id ${id} --target-org "$SF_TARGET_ORG"`,
        { stdio: 'ignore' },
      );
    }
  });

  test('creates an Account through the New modal', async ({ page }) => {
    const accountName = `E2E Account ${process.env.GITHUB_RUN_ID ?? 'local'}`;

    await page.goto('/lightning/o/Account/list');
    await page.getByRole('button', { name: 'New' }).click();
    await page.getByLabel('Account Name').fill(accountName);
    await page.getByRole('button', { name: 'Save' }).click();

    // Assert by deterministic field (Name), not auto-generated ID.
    await expect(page.getByRole('heading', { name: accountName })).toBeVisible();

    // Capture the ID for cleanup. Read it from the URL, never assert on it.
    const url = new URL(page.url());
    const id = url.pathname.split('/').filter(Boolean).pop();
    if (id) createdAccountIds.push(id);
  });
});
