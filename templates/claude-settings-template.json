      "Bash([:*)",
      "Bash([ :*)",
      "Bash(textutil:*)",
      "Bash(sf project deploy start:*)",
      "Bash(sf project deploy resume:*)",
      "Bash(sf project deploy quick:*)",
      "Bash(sf project deploy cancel:*)",
      "Bash(sf agent activate:*)",
      "Bash(sf agent publish:*)",
